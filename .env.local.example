# Copy this file to `.env.local` and fill in your IDs.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# Google Search Console verification token (raw, no quotes)
NEXT_PUBLIC_GSC_VERIFICATION=

# Google Ads conversion ID (for click/conversion tracking — wiring is left to you)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Server-side webhook for lead form (optional — wire this in src/app/api/lead/route.ts)
LEAD_WEBHOOK_URL=
